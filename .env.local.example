NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
ADMIN_WHATSAPP=

# --- LEAD ALERTS (Web Push / VAPID) ---
# Generate the pair once with:
#   node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# Public key is exposed to the browser; private key MUST stay server-side.
NEXT_PUBLIC_XRATED_VAPID_PUBLIC_KEY=
XRATED_VAPID_PRIVATE_KEY=
XRATED_VAPID_SUBJECT=mailto:admin@xratedtrade.com

# --- CUSTOM DOMAIN ADD-ON (Vercel Domains API) ---
# Personal access token with project:write scope. Set in the Vercel
# project env (NOT exposed to client). Missing = the Custom Domain
# editor degrades to a "feature not wired" state.
VERCEL_API_TOKEN=
# Opaque "prj_..." id of this Vercel project. Find in the project
# dashboard → Settings → General → Project ID.
VERCEL_PROJECT_ID=
# Shared secret the 6-hour health-check cron uses to authenticate
# itself against /api/cron/custom-domain-health. Generate any random
# 32+ char string and set the same value in the Vercel cron config.
CRON_SECRET=

# --- AFFILIATE PROGRAMME PHASE 3 EXTERNAL INTEGRATIONS ---
# Every one of these is OPTIONAL. When unset, the corresponding helper
# short-circuits with { ok: true, skipped: true } so dev environments
# never break. See docs/EXTERNAL_INTEGRATIONS.md.

# WhatsApp Business API (Meta) — for transactional WhatsApp messages
# to affiliates (commission approved, payout sent, etc.).
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=

# PayPal Payouts API — for paying affiliates by PayPal.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# live | sandbox — defaults to sandbox.
PAYPAL_PAYOUT_MODE=sandbox

# Wise (TransferWise) Business API — for paying affiliates by Wise.
WISE_API_TOKEN=
WISE_PROFILE_ID=

# IPQualityScore — VPN / proxy detection at affiliate signup.
IPQUALITYSCORE_KEY=

# Cloudflare Turnstile — bot challenge on the affiliate signup form.
# Public site key is exposed to the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

