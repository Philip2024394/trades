NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
ADMIN_WHATSAPP=

# --- ADMIN CUSTOMER SUPPORT ---
# Second-factor passcode required on top of the admin session cookie
# for destructive support actions (e.g. canteen restore). Deliberately
# separate from ADMIN_PASSWORD so a compromised admin session alone
# can't fire a rollback. Rotate periodically.
ADMIN_RESET_PASSCODE=

# --- TRADE CENTER TRADE AUTH ---
# Server-side secret used to hash trade OTPs. Any random 32+ char
# string. Rotating this invalidates in-flight codes but not sessions.
TRADE_OTP_SECRET=

# WhatsApp Business Cloud API (Meta). Missing = OTPs still work in
# dev via the console-log fallback. Set all three for prod send.
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_OTP_TEMPLATE=
# Optional — defaults to en_GB.
META_WHATSAPP_OTP_TEMPLATE_LANG=en_GB

# Twilio SMS. Provide EITHER a Messaging Service SID (preferred; Twilio
# picks the best sender number) OR a single From number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# Resend email — RESEND_API_KEY is shared with lead alerts above.
# Override the sender identity for trade auth emails if you want a
# different "from" than the marketing default.
RESEND_FROM_ADDRESS=Trade Center <noreply@theconstructionnotebook.com>


# --- LEAD ALERTS (Web Push / VAPID) ---
# Generate the pair once with:
#   node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# Public key is exposed to the browser; private key MUST stay server-side.
NEXT_PUBLIC_XRATED_VAPID_PUBLIC_KEY=
XRATED_VAPID_PRIVATE_KEY=
XRATED_VAPID_SUBJECT=mailto:admin@xratedtrade.com

# --- CUSTOM DOMAIN ADD-ON (Vercel Domains API) ---
# Personal access token with project:write scope. Set in the Vercel
# project env (NOT exposed to client). Missing = the Custom Domain
# editor degrades to a "feature not wired" state.
VERCEL_API_TOKEN=
# Opaque "prj_..." id of this Vercel project. Find in the project
# dashboard → Settings → General → Project ID.
VERCEL_PROJECT_ID=
# Shared secret the 6-hour health-check cron uses to authenticate
# itself against /api/cron/custom-domain-health. Generate any random
# 32+ char string and set the same value in the Vercel cron config.
CRON_SECRET=

# --- AFFILIATE PROGRAMME PHASE 3 EXTERNAL INTEGRATIONS ---
# Every one of these is OPTIONAL. When unset, the corresponding helper
# short-circuits with { ok: true, skipped: true } so dev environments
# never break. See docs/EXTERNAL_INTEGRATIONS.md.

# WhatsApp Business API (Meta) — for transactional WhatsApp messages
# to affiliates (commission approved, payout sent, etc.).
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=

# PayPal Payouts API — for paying affiliates by PayPal.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# live | sandbox — defaults to sandbox.
PAYPAL_PAYOUT_MODE=sandbox

# Wise (TransferWise) Business API — for paying affiliates by Wise.
WISE_API_TOKEN=
WISE_PROFILE_ID=

# IPQualityScore — VPN / proxy detection at affiliate signup.
IPQUALITYSCORE_KEY=

# Cloudflare Turnstile — bot challenge on the affiliate signup form.
# Public site key is exposed to the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- BLUEPRINT STUDIO · VERIFIED WIDGETS ---
# Companies House REST API key. Free — register at
# developer.company-information.service.gov.uk. When unset the
# credential manager falls back to self-declared for Companies House.
COMPANIES_HOUSE_API_KEY=

